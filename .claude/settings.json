{
  "permissions": {
    "allow": [
      "Bash(* --help *)",
      "Bash(* --version)",
      "Bash(awk *)",
      "Bash(az *)",
      "Bash(dart analyze *)",
      "Bash(gh *)",
      "Bash(gh api *)",
      "Bash(gh pr *)",
      "Bash(gh run *)",
      "Bash(grep *)",
      "Bash(npm run *)",
      "WebFetch(domain:github.com)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git clean*)",
      "Bash(git stash*)",
      "Bash(git branch -D*)",
      "Bash(git restore*)",
      "Bash(git rm*)",
      "Bash(rm -rf *)"
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "effortLevel": "medium",
  "theme": "auto",
  "editorMode": "vim",
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  }
}
