{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "provider": {
    "anthropic": {
      "models": {},
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    }
  },
  "permission": {
    "rm -rf *": "deny",
    "git commit": "deny",
    "git pull": "deny",
    "git push": "deny"
  }
}
