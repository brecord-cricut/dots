{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "bash": {
      "*": "allow",
      "git add*": "deny",
      "git commit*": "deny",
      "git pull*": "deny",
      "git push*": "deny",
      "git rebase*": "deny",
      "git reset*": "deny",
      "git clean*": "deny",
      "git stash*": "deny",
      "git branch -D*": "deny",
      "git restore*": "deny",
      "git rm*": "deny",
      "rm -rf *": "deny",
      "sudo *": "ask"
    },
    "edit": {
      "~/.local/share/Nextcloud/documents/uinta-project-management/**": "ask"
    },
    "external_directory": {
      "~/.local/share/Nextcloud/documents/uinta-project-management/**": "allow"
    }
  }
}
