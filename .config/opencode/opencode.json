{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "provider": {
    "anthropic": {
      "models": {},
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "rm -rf *": "deny",
      "sudo *": "ask"
    },
    "edit": {
      "~/.local/share/Nextcloud/documents/uinta-project-management/**": "ask"
    },
    "external_directory": {
      "~/.local/share/Nextcloud/documents/uinta-project-management/**": "allow"
    }
  }
}
