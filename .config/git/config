[core]
  pager = delta

[init]
	defaultBranch = main

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true

[merge]
  conflictstyle = diff3

[diff]
  colorMoved = default

[pull]
  rebase = true

[fetch]
  prune = true

[include]
  path = ~/.local/state/git/config

[includeIf "gitdir:~/.local/share/repos/dots/.git"]
  path = ~/.config/git/dots.config
